  "keyFeatures": [
    "Single Sign-On (SSO) with OIDC support for Google, GitHub, Azure AD, and custom providers",
    "Role-Based Access Control (RBAC) with fine-grained permissions powered by SpiceDB",
    "Multi-tenant organization management with projects, groups, and hierarchical resources",
    "Integrated billing and subscription management with Stripe integration",
    "Service user authentication with API keys and RSA JWT tokens",
    "Admin portal for managing users, organizations, and configurations",
    "Comprehensive audit logging for compliance and security tracking",
    "Webhook support for real-time event notifications",
    "Virtual credits system for usage-based billing",
    "Feature entitlement checks for subscription-based access control"
  ],
  "publicApiSurface": [
    "POST /v1beta1/auth/register - User registration",
    "POST /v1beta1/auth/token - Token authentication",
    "GET /v1beta1/users - List users",
    "POST /v1beta1/organizations - Create organization",
    "POST /v1beta1/organizations/{id}/projects - Create project",
    "POST /v1beta1/organizations/{id}/groups - Create group",
    "POST /v1beta1/check - Check resource permission",
    "POST /v1beta1/permissions - Create permission",
    "POST /v1beta1/roles - Create role",
    "POST /v1beta1/policies - Create policy",
    "POST /v1beta1/organizations/{id}/billing - Create billing account",
    "POST /v1beta1/organizations/{org_id}/billing/{billing_id}/subscriptions - Create subscription",
    "GET /v1beta1/organizations/{org_id}/billing/{id}/balance - Get billing balance",
    "frontier serve - Start Frontier server",
    "frontier migrate - Run database migrations",
    "frontier user create - Create user via CLI",
    "frontier organization create - Create organization via CLI"
  ]
